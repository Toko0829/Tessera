{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Storage": {
    "Bucket": "tessera-videos",
    "ServiceUrl": "http://localhost:9000",
    "Region": "us-east-1",
    "ForcePathStyle": true
  },
  "Transcode": {
    "FfmpegPath": "ffmpeg",
    "FfprobePath": "ffprobe",
    "TimeoutMinutes": 10,
    "PollSeconds": 3
  }
}
